doctype html 
html(lang="pt-BR")
    head
    //- Metas - Serve para controlar o responsivo
    //- ============================================
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    meta(charset="utf-8")

    - var title = "CSShortcut | Estudos de Front-end"
    - var description = "Um espaço para organizar e demonstrar meus estudos de HTML, CSS, JavaScript e ferramentas front-end."

    //- SEO
     Descricao que o google le para saber o que é a pagina
    meta(name="description" content=description)
    //- Facilita para o google que a pagina precisa ser indexada
    meta(name="robots" content="index,follow")
    title=title

    //- Open Graph
    meta(property="og:type" content="website")
    meta(property="og:title" content=title)
    meta(property="og:description" content=description)
    meta(property="og:url" content="https://github.com/PaulinhaFigueiredoDev/Front-end_na_vida_real")
    meta(property="og:image" content="assets/img/vivien.png")

    //- Twitter Cards
    meta(name="twitter:card" content="summary_large_image")
    meta(name="twitter:title" content=title)
    meta(name="twitter:description" content=description)
    meta(name="twitter:url" content="https://github.com/PaulinhaFigueiredoDev/Front-end_na_vida_real")
    meta(name="twitter:image" content="assets/img/vivien.png")

    //- Styles
    //- ==========================================================================
    link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/normalize/8.0.1/normalize.css")
    link(rel="stylesheet" href="assets/styles/style.css")

    //- Fonts
    //- ==========================================================================
    link(rel="preconnect" href="https://fonts.googleapis.com")
    link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
    link(href="https://fonts.googleapis.com/css2?family=Lobster&family=Roboto:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet")

    body 
        include ./../partials/header.pug

        main 
            block content

        include ./../partials/footer.pug

        script(type="text/javascript" src="assets/scripts/script.js" defer)
